<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unisa.diem.sad_gruppo6.controllers.MediaPlayerController">

    <padding><Insets top="30" right="20" bottom="30" left="20"/></padding>

    <Label text="Now Playing" style="-fx-font-size: 16; -fx-text-fill: gray;"/>
    <Label fx:id="trackTitleLabel" text="—" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
    <Label fx:id="trackAuthorLabel" text="—" style="-fx-font-size: 16;"/>
    <Label fx:id="statusLabel" text="—" style="-fx-font-size: 14; -fx-text-fill: #1d9e75;"/>

    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="playPauseButton" text="Pausa" onAction="#handlePlayPause"/>
        <Button text="← Libreria" onAction="#handleBack"/>
    </HBox>

</VBox>