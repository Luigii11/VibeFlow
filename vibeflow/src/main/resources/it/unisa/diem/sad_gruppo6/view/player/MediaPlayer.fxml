<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" styleClass="player-bar" stylesheets="@/styles/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unisa.diem.sad_gruppo6.controller.ui.player.MediaPlayerController">
    <padding>
        <Insets bottom="15.0" left="40.0" right="40.0" top="15.0" />
    </padding>
    <children>
        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="2.0">
                    <children>
                        <Label fx:id="trackTitleLabel" styleClass="cell-title-label" text="No track playing" />
                        <Label fx:id="trackAuthorLabel" styleClass="cell-author-label" text="-" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="25.0">
                    <children>
                        <Button fx:id="shuffleButton" mnemonicParsing="false" onAction="#handleShuffle" styleClass="player-btn, icon-small" text="🔀" />
                        <Button mnemonicParsing="false" onAction="#handlePrevious" styleClass="player-btn, icon-medium" text="⏮" />
                        <Button fx:id="playPauseButton" mnemonicParsing="false" onAction="#handlePlayPause" styleClass="play-pause-btn" text="⏵" />
                        <Button mnemonicParsing="false" onAction="#handleNext" styleClass="player-btn, icon-medium" text="⏭" />
                        <Button mnemonicParsing="false" styleClass="player-btn, icon-small" text="🔁" />
                    </children>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox prefWidth="250.0" />
            </children>
        </HBox>
        <Slider fx:id="progressBar" styleClass="player-slider" value="0.0" />
    </children>
</VBox>