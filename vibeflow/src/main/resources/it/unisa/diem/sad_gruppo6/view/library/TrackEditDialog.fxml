<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootContainer" spacing="25.0" styleClass="dialog-pane, main-root" stylesheets="@/styles/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unisa.diem.sad_gruppo6.controller.ui.library.TrackEditDialogController">
    
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <VBox alignment="CENTER" spacing="5.0">
        <children>
            <Label styleClass="brand-title" text="Edit Track" />
            <Label styleClass="cell-meta-label" text="Update the details of the selected track." />
        </children>
    </VBox>

    <GridPane alignment="CENTER" hgap="15.0" vgap="15.0">
        
        <Label style="-fx-text-fill: #AAAAAA; -fx-font-size: 14px; -fx-font-weight: bold;" text="Title" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="titleField" prefWidth="250.0" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label style="-fx-text-fill: #AAAAAA; -fx-font-size: 14px; -fx-font-weight: bold;" text="Author" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="authorField" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label style="-fx-text-fill: #AAAAAA; -fx-font-size: 14px; -fx-font-weight: bold;" text="Duration (s)" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="durationField" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label style="-fx-text-fill: #AAAAAA; -fx-font-size: 14px; -fx-font-weight: bold;" text="Genre" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="genreField" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label style="-fx-text-fill: #AAAAAA; -fx-font-size: 14px; -fx-font-weight: bold;" text="Year" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <TextField fx:id="yearField" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <children>
            <Button fx:id="cancelButton" maxHeight="35.0" maxWidth="90.0" minHeight="35.0" minWidth="90.0" mnemonicParsing="false" onAction="#handleCancel" prefHeight="35.0" prefWidth="90.0" styleClass="button" text="Cancel" />
            <Button fx:id="saveButton" maxHeight="35.0" maxWidth="90.0" minHeight="35.0" minWidth="90.0" mnemonicParsing="false" onAction="#handleSave" prefHeight="35.0" prefWidth="90.0" styleClass="button" text="Save" />
        </children>
    </HBox>

</VBox>