<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<!--
    playlistDetail.fxml
    Vista "Playlist Detail".
    Mostra i brani di una playlist e permette di aggiungerne o rimuoverne.
    Controller: PlaylistDetailController
-->
<VBox spacing="12.0"
      prefWidth="800.0"
      prefHeight="600.0"
      xmlns="http://javafx.com/javafx/23.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unisa.diem.sad_gruppo6.controllers.PlaylistDetailsController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="16" alignment="CENTER_LEFT">
        <Label fx:id="playlistNameLabel"
               style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        <Label fx:id="trackCountLabel"
               style="-fx-text-fill: gray; -fx-font-size: 14px;"/>
    </HBox>

    <Label text="Brani nella playlist:" style="-fx-font-weight: bold;"/>
    <ListView fx:id="playlistTrackListView" prefHeight="200" VBox.vgrow="ALWAYS"/>
    <HBox spacing="10">
        <!--<Button text="Rimuovi traccia selezionata"
                onAction="#handleRemoveTrack"
                style="-fx-background-color: #e0e0e0;"/> 
                -->
    </HBox>

    <HBox alignment="BOTTOM_RIGHT" VBox.vgrow="ALWAYS">
        <Button text="Aggiungi una traccia"
                onAction="#handleAddTrack"
                style="-fx-background-color: #0078d4; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16 8 16;"/>
    </HBox>

</VBox>
