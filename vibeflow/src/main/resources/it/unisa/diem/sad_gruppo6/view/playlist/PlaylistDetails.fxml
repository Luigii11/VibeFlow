<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1080.0" styleClass="main-root" stylesheets="@/styles/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unisa.diem.sad_gruppo6.controller.ui.playlist.PlaylistDetailsController">

    <center>
        <VBox spacing="25.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>
                
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleGoBack" styleClass="home-back-btn" text="🏠" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <Label styleClass="header-icon-label" text="♫" />
                                        <Label fx:id="playlistNameLabel" styleClass="brand-title" text="PLAYLIST NAME" />
                                    </children>
                                </HBox>
                                <Label fx:id="trackCountLabel" styleClass="card-menu-btn" text="Tracks: 0" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Button fx:id="playlistPlayPauseButton" mnemonicParsing="false" onAction="#handlePlayPlaylist" styleClass="player-btn, play-playlist-circle-btn" text="▶" />
                                <HBox alignment="CENTER" spacing="8.0">
                                    <children>
                                        <Button fx:id="playlistShuffleButton" mnemonicParsing="false" onAction="#handlePlaylistShuffle" styleClass="player-btn, icon-small" text="🔀" />
                                        <Button fx:id="playlistLoopButton" mnemonicParsing="false" onAction="#handlePlaylistLoop" styleClass="player-btn, icon-small" text="🔁" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Separator styleClass="content-separator" />

                <HBox fx:id="undoNotificationBar" alignment="CENTER_LEFT" spacing="15.0" styleClass="undo-notification-bar" visible="false" managed="false">
                    <Label fx:id="undoMessageLabel" styleClass="undo-notification-label" text="Track added to playlist." />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="undoCountdownLabel" styleClass="undo-countdown-label" text="10" />
                    <Button fx:id="undoCancelButton" mnemonicParsing="false" onAction="#handleUndo" styleClass="undo-cancel-btn" text="Undo" />
                </HBox>

                <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                    <children>
                        <TableView fx:id="trackTable" styleClass="track-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="titleCol" prefWidth="300.0" text="Title" />
                                <TableColumn fx:id="authorCol" prefWidth="200.0" text="Author" />
                                <TableColumn fx:id="metaCol" prefWidth="200.0" text="Genre/Year" />
                                <TableColumn fx:id="durationCol" prefWidth="100.0" text="Duration" />
                                <TableColumn fx:id="actionCol" prefWidth="80.0" text="Actions" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="addTrackButton" mnemonicParsing="false" onAction="#handleAddTrack" styleClass="add-btn" text="+ Add a track" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <VBox BorderPane.alignment="CENTER">
            <fx:include fx:id="mediaPlayer" source="../player/MediaPlayer.fxml" />
        </VBox>
    </bottom>

</BorderPane>