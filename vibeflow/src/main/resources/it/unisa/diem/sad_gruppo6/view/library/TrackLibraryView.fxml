<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1080.0" styleClass="main-root" stylesheets="@/styles/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unisa.diem.sad_gruppo6.controller.ui.library.TrackLibraryViewController">

    <center>
        <VBox spacing="25.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>
                
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleGoBack" styleClass="home-back-btn" text="←">
                            <tooltip>
                                <Tooltip text="Go back" />
                            </tooltip>
                        </Button>
                        <VBox spacing="2.0">
                            <children>
                                <Label fx:id="headerTitleLabel" styleClass="brand-title" text="Track Library" />
                                <Label fx:id="headerSubtitleLabel" styleClass="cell-meta-label" text="Browse all available tracks" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Separator styleClass="content-separator" />

                <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                    <children>
                        <TableView fx:id="trackTable" styleClass="track-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="titleCol" prefWidth="350.0" text="Title" />
                                <TableColumn fx:id="authorCol" prefWidth="200.0" text="Author" />
                                <TableColumn fx:id="metaCol" prefWidth="200.0" text="Genre/Year" />
                                <TableColumn fx:id="durationCol" prefWidth="100.0" text="Duration" />
                                <TableColumn fx:id="actionCol" prefWidth="130.0" text="Action" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="addTrackButton" minHeight="35.0" mnemonicParsing="false" onAction="#handleAddTrack" prefHeight="35.0" styleClass="add-btn" text="+ Create New Track">
                            <tooltip>
                                <Tooltip text="Add a completely new track to the library" />
                            </tooltip>
                        </Button>
                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

    <bottom>
        <fx:include fx:id="mediaPlayer" source="../player/MediaPlayer.fxml" BorderPane.alignment="CENTER" />
    </bottom>

</BorderPane>